# Database
DATABASE_URL=postgresql+asyncpg://blog:blog_secret@localhost:5432/blog
DATABASE_URL_SYNC=postgresql://blog:blog_secret@localhost:5432/blog

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Access Token
JWT_SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# JWT Refresh Token
JWT_REFRESH_SECRET_KEY=change-me-to-a-different-refresh-secret-key
JWT_REFRESH_EXPIRE_DAYS=7

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Upload
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760

# DeepSeek (for AI chat)
OPENAI_API_KEY=sk-your-deepseek-api-key
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-flash

# Embedding (DeepSeek doesn't support embeddings, keep using OpenAI)
EMBEDDING_API_KEY=sk-your-openai-api-key
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# App
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173
SITE_URL=http://localhost:5173
SITE_NAME=My Blog
SITE_DESCRIPTION=Personal blog RSS feed
